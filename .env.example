PORT=3000
NODE_ENV=development

# JWT — required in production. Generate a strong random string.
JWT_SECRET=

# MongoDB Atlas connection string. Required for persistence.
# Format: mongodb+srv://USER:PASSWORD@cluster.mongodb.net/cinemahub?retryWrites=true&w=majority
MONGODB_URI=
MONGODB_DB_NAME=cinemahub

# TMDB v4 Read Access Token (Bearer) from https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# Google OAuth (for /api/auth/google). Get from Google Cloud Console.
GOOGLE_CLIENT_ID=

# Gmail SMTP for sending OTP / password-reset emails.
# Use a Gmail App Password (Google account → Security → 2-Step Verification → App passwords).
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=CinemaHub <noreply@cinemahub.com>
